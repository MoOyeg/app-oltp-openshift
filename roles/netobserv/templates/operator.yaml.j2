---
# Network Observability Operator (design.md sec 3.5).
apiVersion: v1
kind: Namespace
metadata:
  name: {{ netobserv_operators.netobserv.namespace }}
---
apiVersion: operators.coreos.com/v1
kind: OperatorGroup
metadata:
  name: netobserv-operator-og
  namespace: {{ netobserv_operators.netobserv.namespace }}
spec:
  upgradeStrategy: Default
---
apiVersion: operators.coreos.com/v1alpha1
kind: Subscription
metadata:
  name: {{ netobserv_operators.netobserv.name }}
  namespace: {{ netobserv_operators.netobserv.namespace }}
spec:
  channel: {{ netobserv_operators.netobserv.channel }}
  name: {{ netobserv_operators.netobserv.name }}
  source: {{ netobserv_operators.netobserv.source }}
  sourceNamespace: openshift-marketplace
  installPlanApproval: Automatic

---
# Create the NetObserv Loki bucket in the SAME demo MinIO used by Tempo.
apiVersion: batch/v1
kind: Job
metadata:
  name: netobserv-loki-make-bucket
  namespace: {{ observability_namespace }}
spec:
  backoffLimit: 10
  template:
    spec:
      restartPolicy: OnFailure
      containers:
        - name: mc
          image: {{ minio_mc_image }}
          envFrom:
            - secretRef: { name: minio-creds }
          env:
            # OpenShift restricted SCC: random UID, non-writable HOME.
            - { name: HOME, value: /tmp }
            - { name: MC_CONFIG_DIR, value: /tmp/.mc }
          command:
            - /bin/sh
            - -c
            - |
              set -e
              mkdir -p /tmp/.mc
              until mc alias set local http://minio.{{ observability_namespace }}.svc:9000 \
                    "$MINIO_ROOT_USER" "$MINIO_ROOT_PASSWORD"; do
                echo "waiting for minio..."; sleep 3
              done
              mc mb --ignore-existing local/{{ netobserv_loki_bucket }}
              echo "bucket {{ netobserv_loki_bucket }} ready"

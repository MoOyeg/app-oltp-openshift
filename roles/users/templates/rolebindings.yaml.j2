# Each Dev user gets edit + monitoring-edit on ONLY their app namespace
# (design.md sec 1.4 ownership / sec 3.2 Dev owns ServiceMonitors). Their
# Tempo-tenant read binding is created by the tempo role (tenant-rbac), so
# trace isolation and namespace isolation line up per user.
{% for u in users %}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: {{ u.name }}-edit
  namespace: {{ u.namespace }}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: edit
subjects:
  - kind: User
    apiGroup: rbac.authorization.k8s.io
    name: {{ u.name }}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: {{ u.name }}-monitoring-edit
  namespace: {{ u.namespace }}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: monitoring-edit
subjects:
  - kind: User
    apiGroup: rbac.authorization.k8s.io
    name: {{ u.name }}
{% endfor %}
